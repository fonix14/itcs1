from pathlib import Path
p = Path("app/notifier/main.py")
s = p.read_text(encoding="utf-8")

import re

pattern = r"async def _mark_failed\(.*?return\n"
replacement = """
async def _mark_failed(conn: asyncpg.Connection, row_id: str, attempts: int, err: str) -> None:
    if attempts >= MAX_ATTEMPTS:
        await conn.execute(
            \"""
            UPDATE notification_outbox
            SET status='dead',
                attempts=$2,
                last_error=$3,
                next_retry_at = now()
            WHERE id=$1
            \""",
            row_id,
            attempts,
            str(err)[:4000],
        )
        return

    backoff = _compute_backoff(attempts)

    await conn.execute(
        \"""
        UPDATE notification_outbox
        SET status='queued',
            attempts=$2,
            last_error=$3,
            next_retry_at = now() + make_interval(secs => $4)
        WHERE id=$1
        \""",
        row_id,
        attempts,
        str(err)[:4000],
        int(backoff),
    )
"""
s2 = re.sub(pattern, replacement, s, flags=re.S)
p.write_text(s2, encoding="utf-8")
print("[+] _mark_failed patched")
